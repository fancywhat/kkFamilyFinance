{
  "name": "kk-family-finance",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev -- --host\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev -- --host",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

